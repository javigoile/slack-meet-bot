# Copy this file to .env and fill in your values

# From your Slack App settings → "Basic Information" → "Signing Secret"
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# The URL that returns a Google Meet link (can be a redirect or JSON/HTML response)
MEET_URL=https://meet.google.com/getalink

# Port the server listens on (optional, defaults to 3000)
PORT=3000
